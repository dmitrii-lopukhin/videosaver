# === Bot (Go) ===
# Required: get from @BotFather
BOT_TOKEN=

# Redis (default points to the in-compose service)
REDIS_URL=redis://redis:6379/0

# Insta-resolver (Python service)
INSTA_RESOLVER_URL=http://insta-resolver:8000

# Cache TTL in seconds (24h)
CACHE_TTL_SEC=86400

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Telegram channel for uploading videos to get permanent file_ids (inline-in-chat feature).
# Bot must be admin with "Post Messages" permission. Format: -100XXXXXXXXXX
STORAGE_CHANNEL_ID=

# === Insta-resolver (Python) ===
SESSIONS_DIR=/app/sessions
MIN_REQUEST_INTERVAL_SEC=2
RATE_LIMIT_COOLDOWN_SEC=300
# Optional residential proxy for Instagram (roadmap v0.2); leave empty to go direct
INSTA_PROXY_URL=
